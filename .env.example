# ─── Server ───
PORT=3000
NODE_ENV=production
BASE_URL=https://efes.example.com

# ─── MongoDB ───
MONGODB_URI=mongodb://localhost:27017/efes_delivery

# ─── JWT ───
JWT_SECRET=your_jwt_secret_key_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_key_here

# ─── Telegram Bot ───
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=efes_kebab_bot
WEBHOOK_SECRET=your_webhook_secret_here

# ─── Mini-App URL (to'lovdan keyin qaytish uchun) ───
WEBAPP_URL=https://t.me/efeskebab_bot/app

# ─── Click ───
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_MERCHANT_USER_ID=your_click_merchant_user_id

# ─── Payme ───
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_MERCHANT_KEY=your_payme_merchant_key

# ─── Cloudinary (rasm saqlash — ixtiyoriy, bo'lmasa local disk ishlatiladi) ───
# https://cloudinary.com dan bepul akkaunt oling
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Admin birinchi marta yaratish (keyin o'chirish mumkin) ───
ADMIN_INIT_PASSWORD=your_strong_admin_password_here

# ─── CORS (vergul bilan ajratilgan ruxsat etilgan domenlar) ───
# Bo'sh qoldirilsa barcha origin qabul qilinadi (faqat dev uchun)
ALLOWED_ORIGINS=https://efes.example.com,https://t.me

# ─── Admin tiklash (maxfiy kalit) ───
ADMIN_RESET_SECRET=your_emergency_reset_secret_here

# ─── SMS (ixtiyoriy) ───
SMS_TOKEN=nkjnkjn
SMS_FROM=EFES

# ─── Frontend (Vite) ───
VITE_BOT_USERNAME=efes_kebab_bot
